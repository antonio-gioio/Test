{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5000",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=aisstream;Username=postgres;Password=ais"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:4200"]
  },
  "Cluster": {
    "Role": "All"
  },
  "Redis": {
    "ConnectionString": ""
  },
  "Jwt": {
    "Issuer": "AisStream.Api",
    "Audience": "AisStream.Client",
    "Key": "dev-only-insecure-signing-key-change-me-please-32+chars",
    "ExpiryHours": 24
  },
  "Ais": {
    "_Provider_options": "Auto | Simulator | AisStream | Digitraffic | MarineTraffic | Datalastic",
    "Provider": "Auto",
    "VesselTtlMinutes": 30,
    "BoundingBoxes": [
      [[-90, -180], [90, 180]]
    ],
    "AisStream": {
      "_comment": "Free, terrestrial WebSocket feed. Get a key at https://aisstream.io",
      "ApiKey": "",
      "Url": "wss://stream.aisstream.io/v0/stream",
      "MessageTypes": ["PositionReport", "ShipStaticData"]
    },
    "Digitraffic": {
      "_comment": "Free, open MQTT AIS for Finnish/Baltic waters. No credentials required.",
      "Url": "wss://meri.digitraffic.fi:443/mqtt"
    },
    "MarineTraffic": {
      "_comment": "Paid, global. Free trial via account credits. https://www.marinetraffic.com",
      "ApiKey": "",
      "BaseUrl": "https://services.marinetraffic.com/api/exportvessels/v:8",
      "PollSeconds": 60
    },
    "Datalastic": {
      "_comment": "Paid, global. Free trial available. https://datalastic.com",
      "ApiKey": "",
      "BaseUrl": "https://api.datalastic.com/api/v0",
      "Latitude": 50.5,
      "Longitude": -1.0,
      "RadiusKm": 100,
      "PollSeconds": 60
    }
  }
}
